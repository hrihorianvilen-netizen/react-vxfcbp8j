# Supabase — copy to .env.local and fill in from your project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secret. NEVER expose with NEXT_PUBLIC_. Used by admin/server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Roadmap stage 5 — AI coach (pick the provider you wire up)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Roadmap stage 3 — passwordless auth via WhatsApp/SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
